//@version=6
indicator("HTF Wick Sweep OB - Clean DT Core v1.6 Debug", overlay=true, max_boxes_count=500, max_labels_count=500)

// =============================================================================
// CLEAN REBUILD NOTES
// =============================================================================
// DT in this script means Deepest Touch (a price), not Date/Time.
// Core model:
//   c1 = liquidity candle/level source
//   c2 = sweep candle -> creates a pending zone from c2 protruding wick range
//   c3 = immediate next HTF candle -> decides Fresh / Mitigated / Invalid+Promote
//   Cx = future HTF candles -> update DT only when they go deeper into the zone
//
// Direction is represented by one flag:
//   DIR_BULL = bullish/support zone below price
//   DIR_BEAR = bearish/resistance zone above price
// =============================================================================

// -----------------------------------------------------------------------------
// Inputs
// -----------------------------------------------------------------------------
htfTf = input.timeframe("60", "HTF Timeframe", group="1. Core")
lookback = input.int(1, "Liquidity Lookback", minval=1, maxval=20, group="1. Core")
minSweepTicks = input.int(1, "Minimum Sweep Distance (ticks)", minval=1, maxval=100, group="1. Core")
fullBufferTicks = input.int(1, "Full Traversal Buffer (ticks)", minval=0, maxval=20, group="1. Core", tooltip="Extra ticks required beyond the far edge before c3 is considered a full invalidation.")
minDtMoveTicks = input.int(1, "Minimum DT Move (ticks)", minval=0, maxval=50, group="1. Core", tooltip="A zone is marked mitigated only when price moves deeper than current DT by at least this many ticks.")
dualSweepMode = input.string("Candle Direction", "Dual Sweep Resolution", options=["Candle Direction", "Larger Sweep"], group="1. Core", tooltip="When the same HTF candle sweeps both high and low liquidity, choose direction by candle body direction or by larger sweep distance.")

zoneAnchorMode = input.string("Strict Wick", "Zone Body Anchor", options=["Strict Wick", "User Spec"], group="1. Core", tooltip="Strict Wick = true protruding wick only: bull top=min(O,C), bear bottom=max(O,C). User Spec = wider body anchor: bull top=max(O,C), bear bottom=min(O,C).")
promoteC3OnFull = input.bool(true, "Promote c3 On Full Invalidation", group="1. Core")

maxZones = input.int(20, "Maximum Zones", minval=1, maxval=450, group="2. Display")
extendFreshRight = input.bool(false, "Extend Fresh Zones Right", group="2. Display")
extendMitigatedRight = input.bool(false, "Extend Mitigated Zones Right", group="2. Display")
showLabels = input.bool(true, "Show Labels", group="2. Display")
showZoneIds = input.bool(true, "Show Zone IDs In Labels", group="2. Display")
showDtDebug = input.bool(false, "Show DT Debug Labels", group="2. Display")
showC2Debug = input.bool(false, "Show C2/C3 Debug Markers", group="2. Display", tooltip="Shows compact labels for sweep candidates and c3 decisions to diagnose missing/fresh/mitigated zones.")
dtDebugKeep = input.int(200, "DT Debug Labels To Keep", minval=1, maxval=450, group="2. Display", tooltip="TradingView max_labels_count is 500. Keep this below that to leave room for zone labels.")
showDashboard = input.bool(false, "Show Dashboard", group="2. Display")
dashPos = input.string("top_right", "Dashboard Position", options=["top_left", "top_right", "bottom_left", "bottom_right"], group="2. Display")

bullFreshColor = input.color(color.new(color.green, 82), "Bull Fresh", group="3. Colors")
bearFreshColor = input.color(color.new(color.red, 82), "Bear Fresh", group="3. Colors")
mitigatedColor = input.color(color.new(color.orange, 82), "Mitigated Zone", group="3. Colors")

// -----------------------------------------------------------------------------
// Constants and types
// -----------------------------------------------------------------------------
DIR_BULL = 1
DIR_BEAR = -1
ST_FRESH = 0
ST_MITIGATED = 1

// One structure, direction flag determines bullish/bearish logic.
type Zone
    int id
    int dir
    int status
    float origTop
    float origBottom
    float dt
    int sweepTime
    int decisionTime
    int lastUpdateTime
    box bx
    label lb

var Zone[] zones = array.new<Zone>()
var label[] dtDebugLabels = array.new<label>()

// Pending c2 waiting for c3 decision.
var bool pendActive = false
var int pendDir = 0
var float pendOrigTop = na
var float pendOrigBottom = na
var float pendDt = na
var int pendSweepTime = na
var int pendSweepCloseTime = na

var string lastEvent = "Idle"
var int htfEventsSeen = 0

// -----------------------------------------------------------------------------
// HTF data
// -----------------------------------------------------------------------------
// HTF candle feed. With lookahead_off, historical HTF values become available
// only when the HTF candle is confirmed. This matches the earlier detection
// style better than the extra [1] shift, which delayed/missed valid zones.
[hTime, hCloseTime, hOpen, hHigh, hLow, hClose, liqHigh, liqLow, hAtr] = request.security(
     syminfo.tickerid,
     htfTf,
     [time, time_close, open, high, low, close, ta.highest(high[1], lookback), ta.lowest(low[1], lookback), ta.atr(14)],
     lookahead=barmerge.lookahead_off)

chartSec = timeframe.in_seconds(timeframe.period)
htfSec = timeframe.in_seconds(htfTf)
isLowerThanHTF = chartSec < htfSec
chgHtfTime = ta.change(hTime)
newHtf = isLowerThanHTF and not na(hTime) and chgHtfTime != 0

buf = syminfo.mintick * fullBufferTicks
minSweep = syminfo.mintick * minSweepTicks

// -----------------------------------------------------------------------------
// Helpers
// -----------------------------------------------------------------------------
f_pos(string p) =>
    switch p
        "top_left" => position.top_left
        "top_right" => position.top_right
        "bottom_left" => position.bottom_left
        "bottom_right" => position.bottom_right
        => position.top_right

f_statusText(int st) =>
    st == ST_FRESH ? "Fresh" : "Mitigated"

f_dirText(int dir) =>
    dir == DIR_BULL ? "Bull" : "Bear"

f_dtPriceText(float v) =>
    na(v) ? "na" : str.tostring(v, format.mintick)

f_visibleTop(Zone z) =>
    z.dir == DIR_BULL ? z.dt : z.origTop

f_visibleBottom(Zone z) =>
    z.dir == DIR_BULL ? z.origBottom : z.dt

f_color(Zone z) =>
    z.status == ST_MITIGATED ? mitigatedColor : (z.dir == DIR_BULL ? bullFreshColor : bearFreshColor)

f_shouldExtend(Zone z) =>
    z.status == ST_FRESH ? extendFreshRight : z.status == ST_MITIGATED ? extendMitigatedRight : false

f_zoneText(Zone z) =>
    (showZoneIds ? "#" + str.tostring(z.id) + " " : "") + f_dirText(z.dir) + " HTF OB" +
     "\nStatus: " + f_statusText(z.status) +
     "\nOrig: " + str.tostring(z.origBottom, format.mintick) + " - " + str.tostring(z.origTop, format.mintick) +
     "\nDT: " + f_dtPriceText(z.dt) +
     "\nVisible: " + str.tostring(f_visibleBottom(z), format.mintick) + " - " + str.tostring(f_visibleTop(z), format.mintick)

f_overlap(int dir, float top, float bottom, float hi, float lo) =>
    // Any intersection with the original zone range.
    hi >= bottom and lo <= top

f_fullTraversal(int dir, float top, float bottom, float hi, float lo, float cl) =>
    // Full traversal requires reaching the far edge and closing beyond it.
    dir == DIR_BULL ? (lo <= bottom - buf and cl < bottom - buf) : (hi >= top + buf and cl > top + buf)

f_deepestInside(int dir, float top, float bottom, float hi, float lo) =>
    // DT is a price inside the zone. Clamp extremes to the original zone range.
    dir == DIR_BULL ? math.max(lo, bottom) : math.min(hi, top)

f_goesDeeper(int dir, float candidateDt, float currentDt) =>
    dir == DIR_BULL ? candidateDt < currentDt - syminfo.mintick * minDtMoveTicks : candidateDt > currentDt + syminfo.mintick * minDtMoveTicks

f_pushDebug(string txt, int x, float y, color c) =>
    if showDtDebug
        lb = label.new(x, y, txt, xloc=xloc.bar_time, style=label.style_label_left, color=c, textcolor=color.white, size=size.small)
        array.push(dtDebugLabels, lb)
        while array.size(dtDebugLabels) > dtDebugKeep
            old = array.shift(dtDebugLabels)
            if not na(old)
                label.delete(old)

f_pushCoreDebug(string txt, int x, float y, color c) =>
    if showDtDebug or showC2Debug
        lb = label.new(x, y, txt, xloc=xloc.bar_time, style=label.style_label_left, color=c, textcolor=color.white, size=size.small)
        array.push(dtDebugLabels, lb)
        while array.size(dtDebugLabels) > dtDebugKeep
            old = array.shift(dtDebugLabels)
            if not na(old)
                label.delete(old)

f_deleteZone(int i) =>
    z = array.get(zones, i)
    if not na(z.bx)
        box.delete(z.bx)
    if not na(z.lb)
        label.delete(z.lb)
    array.remove(zones, i)

f_applyVisual(int i) =>
    z = array.get(zones, i)
    c = f_color(z)
    vTop = f_visibleTop(z)
    vBottom = f_visibleBottom(z)
    if not na(z.bx)
        box.set_top(z.bx, vTop)
        box.set_bottom(z.bx, vBottom)
        box.set_bgcolor(z.bx, c)
        box.set_border_color(z.bx, color.new(c, 0))
        box.set_right(z.bx, z.lastUpdateTime)
        box.set_extend(z.bx, f_shouldExtend(z) ? extend.right : extend.none)
    if showLabels
        if na(z.lb)
            z.lb := label.new(z.lastUpdateTime, z.dir == DIR_BULL ? vBottom : vTop, f_zoneText(z), xloc=xloc.bar_time, style=z.dir == DIR_BULL ? label.style_label_up : label.style_label_down, color=color.new(c, 0), textcolor=color.white, size=size.small)
        else
            label.set_x(z.lb, z.lastUpdateTime)
            label.set_y(z.lb, z.dir == DIR_BULL ? vBottom : vTop)
            label.set_text(z.lb, f_zoneText(z))
            label.set_color(z.lb, color.new(c, 0))
    else if not na(z.lb)
        label.delete(z.lb)
        z.lb := na
    array.set(zones, i, z)

f_addZone(int dir, int status, float top, float bottom, float dt, int sweepT, int decisionT, string reason) =>
    while array.size(zones) >= maxZones
        f_deleteZone(0)

    z = Zone.new()
    z.id := array.size(zones) + 1
    z.dir := dir
    z.status := status
    z.origTop := top
    z.origBottom := bottom
    z.dt := dt
    z.sweepTime := sweepT
    z.decisionTime := decisionT
    z.lastUpdateTime := decisionT

    vTop = dir == DIR_BULL ? dt : top
    vBottom = dir == DIR_BULL ? bottom : dt
    c = status == ST_MITIGATED ? mitigatedColor : (dir == DIR_BULL ? bullFreshColor : bearFreshColor)
    z.bx := box.new(sweepT, vTop, decisionT, vBottom, xloc=xloc.bar_time, extend=status == ST_FRESH ? (extendFreshRight ? extend.right : extend.none) : (extendMitigatedRight ? extend.right : extend.none), border_color=color.new(c, 0), bgcolor=c)
    z.lb := na
    array.push(zones, z)
    f_applyVisual(array.size(zones) - 1)

    f_pushDebug("ADD ZONE #" + str.tostring(z.id) +
     "\nReason: " + reason +
     "\nDir: " + f_dirText(dir) +
     "\nStatus: " + f_statusText(status) +
     "\nOrigTop: " + str.tostring(top, format.mintick) +
     "\nOrigBottom: " + str.tostring(bottom, format.mintick) +
     "\nDT: " + str.tostring(dt, format.mintick) +
     "\nVisibleTop: " + str.tostring(vTop, format.mintick) +
     "\nVisibleBottom: " + str.tostring(vBottom, format.mintick), decisionT, dir == DIR_BULL ? vBottom : vTop, color.new(color.blue, 0))


f_zoneFromCandle(int dir, float o, float h, float l, float c) =>
    // Returns [top, bottom]. User Spec follows latest DT definition.
    bullTop = zoneAnchorMode == "User Spec" ? math.max(o, c) : math.min(o, c)
    bearBottom = zoneAnchorMode == "User Spec" ? math.min(o, c) : math.max(o, c)
    top = dir == DIR_BULL ? bullTop : h
    bottom = dir == DIR_BULL ? l : bearBottom
    [top, bottom]

// -----------------------------------------------------------------------------
// Main HTF step engine
// -----------------------------------------------------------------------------
if newHtf
    htfEventsSeen += 1

    // 1) Resolve pending c2 with immediate next candle c3.
    promoted = false
    if pendActive
        overlap = f_overlap(pendDir, pendOrigTop, pendOrigBottom, hHigh, hLow)
        full = f_fullTraversal(pendDir, pendOrigTop, pendOrigBottom, hHigh, hLow, hClose)
        c3Dt = f_deepestInside(pendDir, pendOrigTop, pendOrigBottom, hHigh, hLow)
        deeper = overlap and f_goesDeeper(pendDir, c3Dt, pendDt)
        decisionTxt = not overlap ? "FRESH - no overlap" : full ? "FULL/PROMOTE" : deeper ? "MITIGATED - deeper DT" : "FRESH - overlap not deeper"

        f_pushCoreDebug("C3 DECISION" +
         "\nDir: " + f_dirText(pendDir) +
         "\nZone Top/Bottom: " + str.tostring(pendOrigTop, format.mintick) + " / " + str.tostring(pendOrigBottom, format.mintick) +
         "\nCurrent DT: " + str.tostring(pendDt, format.mintick) +
         "\nc3 H/L/C: " + str.tostring(hHigh, format.mintick) + " / " + str.tostring(hLow, format.mintick) + " / " + str.tostring(hClose, format.mintick) +
         "\nOverlap: " + str.tostring(overlap) +
         "\nFull: " + str.tostring(full) +
         "\nc3 DT candidate: " + str.tostring(c3Dt, format.mintick) +
         "\nGoes deeper: " + str.tostring(deeper) +
         "\nDecision: " + decisionTxt +
         "\nMin DT Move ticks: " + str.tostring(minDtMoveTicks), hCloseTime, pendDir == DIR_BULL ? pendOrigBottom : pendOrigTop, color.new(color.navy, 0))

        if not overlap
            f_addZone(pendDir, ST_FRESH, pendOrigTop, pendOrigBottom, pendDt, pendSweepTime, hCloseTime, "c3 no overlap")
            lastEvent := "Fresh " + f_dirText(pendDir) + " zone"
            pendActive := false
            pendDir := 0
            pendOrigTop := na
            pendOrigBottom := na
            pendDt := na
            pendSweepTime := na
            pendSweepCloseTime := na
        else if full
            // Old c2 zone is invalid. Optional promotion: c3 becomes new c2.
            oldDir = pendDir
            f_pushDebug("c3 FULL INVALIDATION" +
             "\nOld Dir: " + f_dirText(oldDir) +
             "\nOld Top/Bottom: " + str.tostring(pendOrigTop, format.mintick) + " / " + str.tostring(pendOrigBottom, format.mintick) +
             "\nc3 H/L/C: " + str.tostring(hHigh, format.mintick) + " / " + str.tostring(hLow, format.mintick) + " / " + str.tostring(hClose, format.mintick) +
             "\nPromote c3: " + str.tostring(promoteC3OnFull), hCloseTime, oldDir == DIR_BULL ? pendOrigBottom : pendOrigTop, color.new(color.red, 0))
            pendActive := false
            pendDir := 0
            pendOrigTop := na
            pendOrigBottom := na
            pendDt := na
            pendSweepTime := na
            pendSweepCloseTime := na
            if promoteC3OnFull
                [pTop, pBottom] = f_zoneFromCandle(oldDir, hOpen, hHigh, hLow, hClose)
                pendActive := true
                pendDir := oldDir
                pendOrigTop := pTop
                pendOrigBottom := pBottom
                pendDt := oldDir == DIR_BULL ? pTop : pBottom
                pendSweepTime := hTime
                pendSweepCloseTime := hCloseTime
                f_pushDebug("PENDING c2" +
                 "\nReason: promoted c3 after full invalidation" +
                 "\nDir: " + f_dirText(oldDir) +
                 "\nOrigTop: " + str.tostring(pTop, format.mintick) +
                 "\nOrigBottom: " + str.tostring(pBottom, format.mintick) +
                 "\nInitial DT: " + str.tostring(pendDt, format.mintick), hCloseTime, oldDir == DIR_BULL ? pBottom : pTop, color.new(color.purple, 0))
                promoted := true
                lastEvent := "c3 promoted as new sweep"
            else
                lastEvent := "c3 full invalidation"
        else
            // If c3 overlaps but does NOT go deeper than the initial body-extreme DT,
            // it has not consumed any new part of the zone. Keep it Fresh.
            // Only mark Mitigated when DT actually moves deeper.
            newDt = deeper ? c3Dt : pendDt
            newStatus = deeper ? ST_MITIGATED : ST_FRESH
            f_addZone(pendDir, newStatus, pendOrigTop, pendOrigBottom, newDt, pendSweepTime, hCloseTime, deeper ? "c3 partial overlap deeper" : "c3 overlap but not deeper -> fresh")
            lastEvent := (deeper ? "Mitigated " : "Fresh ") + f_dirText(pendDir) + " zone"
            pendActive := false
            pendDir := 0
            pendOrigTop := na
            pendOrigBottom := na
            pendDt := na
            pendSweepTime := na
            pendSweepCloseTime := na

    // 2) Update active zones using future Cx candles.
    //    Only update when the candle goes deeper than the current DT.
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            z = array.get(zones, i)
            // Avoid updating a zone on the same HTF candle that decided/created it.
            if hCloseTime > z.decisionTime
                overlapsCx = f_overlap(z.dir, z.origTop, z.origBottom, hHigh, hLow)
                if overlapsCx
                    cxDt = f_deepestInside(z.dir, z.origTop, z.origBottom, hHigh, hLow)
                    if f_goesDeeper(z.dir, cxDt, z.dt)
                        oldDt = z.dt
                        z.dt := cxDt
                        z.status := ST_MITIGATED
                        z.lastUpdateTime := hCloseTime
                        array.set(zones, i, z)
                        f_applyVisual(i)
                        lastEvent := "DT deeper: " + f_dirText(z.dir)
                        f_pushDebug("DT UPDATE" +
                         "\nDir: " + f_dirText(z.dir) +
                         "\nOld DT: " + str.tostring(oldDt, format.mintick) +
                         "\nNew DT: " + str.tostring(cxDt, format.mintick) +
                         "\nOrigTop: " + str.tostring(z.origTop, format.mintick) +
                         "\nOrigBottom: " + str.tostring(z.origBottom, format.mintick) +
                         "\nCx H/L/C: " + str.tostring(hHigh, format.mintick) + " / " + str.tostring(hLow, format.mintick) + " / " + str.tostring(hClose, format.mintick), hCloseTime, z.dir == DIR_BULL ? f_visibleBottom(z) : f_visibleTop(z), color.new(color.teal, 0))

    // 3) If c3 was not promoted into a new pending zone, detect a new c2 sweep.
    if not pendActive and not promoted
        bearSweepDist = hHigh - liqHigh
        bullSweepDist = liqLow - hLow
        bearSweep = not na(liqHigh) and hHigh > liqHigh and bearSweepDist >= minSweep and hClose < liqHigh
        bullSweep = not na(liqLow) and hLow < liqLow and bullSweepDist >= minSweep and hClose > liqLow

        if showC2Debug and (bearSweep or bullSweep)
            f_pushCoreDebug("C2 SWEEP CANDIDATE" +
             "\nBearSweep: " + str.tostring(bearSweep) + " dist=" + str.tostring(bearSweepDist, format.mintick) +
             "\nBullSweep: " + str.tostring(bullSweep) + " dist=" + str.tostring(bullSweepDist, format.mintick) +
             "\nLiqHigh/Low: " + str.tostring(liqHigh, format.mintick) + " / " + str.tostring(liqLow, format.mintick) +
             "\nO/H/L/C: " + str.tostring(hOpen, format.mintick) + " / " + str.tostring(hHigh, format.mintick) + " / " + str.tostring(hLow, format.mintick) + " / " + str.tostring(hClose, format.mintick) +
             "\nStrict bull/bear body: " + str.tostring(math.min(hOpen, hClose), format.mintick) + " / " + str.tostring(math.max(hOpen, hClose), format.mintick) +
             "\nUser bull/bear body: " + str.tostring(math.max(hOpen, hClose), format.mintick) + " / " + str.tostring(math.min(hOpen, hClose), format.mintick), hCloseTime, hHigh, color.new(color.maroon, 0))

        chosenDir = 0
        if bearSweep and bullSweep
            if dualSweepMode == "Candle Direction"
                chosenDir := hClose >= hOpen ? DIR_BULL : DIR_BEAR
            else
                chosenDir := bearSweepDist >= bullSweepDist ? DIR_BEAR : DIR_BULL
        else if bearSweep
            chosenDir := DIR_BEAR
        else if bullSweep
            chosenDir := DIR_BULL

        if chosenDir != 0
            [zTop, zBottom] = f_zoneFromCandle(chosenDir, hOpen, hHigh, hLow, hClose)
            if zTop > zBottom
                pendActive := true
                pendDir := chosenDir
                pendOrigTop := zTop
                pendOrigBottom := zBottom
                pendDt := chosenDir == DIR_BULL ? zTop : zBottom
                pendSweepTime := hTime
                pendSweepCloseTime := hCloseTime
                f_pushDebug("PENDING c2" +
                 "\nReason: sweep c2" +
                 "\nDual mode: " + dualSweepMode +
                 "\nAnchor mode: " + zoneAnchorMode +
                 "\nDir: " + f_dirText(chosenDir) +
                 "\nBear/Bull Sweep: " + str.tostring(bearSweep) + " / " + str.tostring(bullSweep) +
                 "\nOrigTop: " + str.tostring(zTop, format.mintick) +
                 "\nOrigBottom: " + str.tostring(zBottom, format.mintick) +
                 "\nInitial DT: " + str.tostring(pendDt, format.mintick), hCloseTime, chosenDir == DIR_BULL ? zBottom : zTop, color.new(color.purple, 0))
                lastEvent := "Pending " + f_dirText(chosenDir) + " c2"

// Clean debug labels when disabled.
if barstate.islast and not showDtDebug and not showC2Debug and array.size(dtDebugLabels) > 0
    for i = 0 to array.size(dtDebugLabels) - 1
        label.delete(array.get(dtDebugLabels, i))
    array.clear(dtDebugLabels)

// Refresh visuals on last bar for extension/label toggles.
if barstate.islast and array.size(zones) > 0
    for i = 0 to array.size(zones) - 1
        f_applyVisual(i)

// -----------------------------------------------------------------------------
// Dashboard
// -----------------------------------------------------------------------------
var table dash = table.new(f_pos(dashPos), 2, 10, frame_color=color.gray, frame_width=1)
if barstate.islast and showDashboard
    table.clear(dash, 0, 0, 1, 9)
    table.cell(dash, 0, 0, isLowerThanHTF ? "Clean DT Core v1.6" : "DISABLED", text_color=color.white, bgcolor=isLowerThanHTF ? color.new(color.blue, 25) : color.new(color.red, 10))
    table.cell(dash, 1, 0, syminfo.ticker, text_color=color.white, bgcolor=isLowerThanHTF ? color.new(color.blue, 25) : color.new(color.red, 10))
    table.cell(dash, 0, 1, "Chart / HTF", text_color=color.gray)
    table.cell(dash, 1, 1, timeframe.period + " / " + htfTf)
    table.cell(dash, 0, 2, "Anchor Mode", text_color=color.gray)
    table.cell(dash, 1, 2, zoneAnchorMode)
    table.cell(dash, 0, 3, "Pending", text_color=color.gray)
    table.cell(dash, 1, 3, pendActive ? f_dirText(pendDir) + " DT " + f_dtPriceText(pendDt) : "None")
    table.cell(dash, 0, 4, "Zones", text_color=color.gray)
    table.cell(dash, 1, 4, str.tostring(array.size(zones)))
    table.cell(dash, 0, 5, "HTF Events", text_color=color.gray)
    table.cell(dash, 1, 5, str.tostring(htfEventsSeen))
    table.cell(dash, 0, 6, "Last Event", text_color=color.gray)
    table.cell(dash, 1, 6, lastEvent)
    table.cell(dash, 0, 7, "Last HTF O/H/L/C", text_color=color.gray)
    table.cell(dash, 1, 7, str.tostring(hOpen, format.mintick) + " / " + str.tostring(hHigh, format.mintick) + " / " + str.tostring(hLow, format.mintick) + " / " + str.tostring(hClose, format.mintick))
    table.cell(dash, 0, 8, "Debug", text_color=color.gray)
    table.cell(dash, 1, 8, (showDtDebug or showC2Debug) ? "ON " + str.tostring(array.size(dtDebugLabels)) : "OFF")
    table.cell(dash, 0, 9, "Status", text_color=color.gray)
    table.cell(dash, 1, 9, isLowerThanHTF ? "Running" : "Use chart TF < HTF")

if barstate.islast and not showDashboard
    table.clear(dash, 0, 0, 1, 9)
